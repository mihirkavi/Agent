OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_TASK_MODEL=gpt-5.4-pro
OPENAI_FAST_MODEL=gpt-5.4
PORT=8787
CLIENT_ORIGIN=http://localhost:3000
BROWSER_HEADLESS=true
DISABLE_BROWSER_AUTOMATION=false
# Comma-separated bare hostnames that can be automated without a per-task approval.
ALLOWED_AUTOMATION_DOMAINS=calendly.com,amazon.com,doordash.com
